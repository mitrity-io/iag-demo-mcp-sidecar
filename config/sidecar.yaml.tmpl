edge_node_id: "${MITRITY_EDGE_NODE_ID}"
api_key: "${MITRITY_EDGE_API_KEY}"
agent_id: "${MITRITY_AGENT_ID}"

control_plane:
  base_url: "${MITRITY_CONTROL_PLANE_URL}"

upstream_command: "/usr/local/bin/demo-tools"
upstream_args: ["--workspace", "/workspace"]

logging:
  level: "info"
  format: "text"

cache:
  profile_ttl: "1m"
  max_entries: 100

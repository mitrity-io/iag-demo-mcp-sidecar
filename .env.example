# Required — Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Required — MITRITY control plane connection
MITRITY_EDGE_API_KEY=mit_...
MITRITY_CONTROL_PLANE_URL=https://api.mitrity.com
MITRITY_EDGE_NODE_ID=your-edge-node-uuid
MITRITY_AGENT_ID=your-agent-uuid

# Optional
MITRITY_DEMO_SPEED=normal
ANTHROPIC_MODEL=claude-sonnet-4-20250514
